# MongoDB — any host your app can reach (same VPS, another VPS, Atlas, …).
# Default in docker-compose is the bundled `mongo` service; override for external DB.

# Bundled compose stack (hostname = service name `mongo`):
# MONGODB_URI=mongodb://mongo:27017/vps-monitoring

# Same machine as app, Mongo listens on host (Linux Docker often needs host.docker.internal):
# MONGODB_URI=mongodb://host.docker.internal:27017/vps-monitoring

# Remote VPS with auth (replace user, pass, host, db; authSource often "admin"):
# MONGODB_URI=mongodb://user:pass@db.example.com:27017/vps-monitoring?authSource=admin

# MongoDB Atlas (get SRV string from Atlas UI → Connect → Drivers):
# MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/vps-monitoring?retryWrites=true&w=majority

# If ping works but this app times out: force IPv4 DNS resolution (rare).
# MONGODB_FAMILY=4

MONGODB_URI=mongodb://localhost:27017/vps-monitoring

# JWT secret (generate with: openssl rand -hex 64)
JWT_SECRET=replace-me-with-a-long-random-string-please-change-this

# Public URL where this dashboard is hosted (used by install script)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: how many seconds before an agent is considered offline
AGENT_OFFLINE_AFTER_SECONDS=60

# Telegram overload alerts: configure in the web UI (Settings), stored in MongoDB.

# Chatwork notification
CHATWORK_API_KEY=
CHATWORK_ROOM_ID=